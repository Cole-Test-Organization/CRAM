# Calendar exporter — Cloudflare Access service-token credentials (TEMPLATE).
#
# Copy to calendar/.env (gitignored) and fill in real values. NOTE: nothing in
# this repo reads these at runtime — the Apps Script reads them from its own
# Script Properties (Apps Script editor → Project Settings → Script Properties).
# calendar/.env is just a local store so the values live next to the script.
# See calendar/README.md.
#
# Source: Cloudflare Zero Trust → Access → Service Auth → your Service Token.

CF_ACCESS_CLIENT_ID=your-service-token-client-id.access
CF_ACCESS_CLIENT_SECRET=your-service-token-client-secret

# Where the script POSTs (also set as ENDPOINT_URL in the .gs CONFIG).
ENDPOINT_URL=https://calendar.example.com
