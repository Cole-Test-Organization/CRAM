# CRAM — example environment file. Copy to .env or run scripts/setup.sh
# to generate one interactively.

# ── Identity ─────────────────────────────────────────────────────────
# Shape the agent's system prompt and CRM workflow guidance.
VENDOR_NAME="Acme Corp"
USER_ROLE="Sales Engineer"

# ── Postgres ─────────────────────────────────────────────────────────
POSTGRES_USER=crm
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=crm
POSTGRES_PORT=5432

# Connection string (defaults to the in-compose db service if unset)
# DATABASE_URL=postgres://crm:devpassword@db:5432/crm

# Set true when connecting to managed Postgres (Azure / RDS / etc.)
DATABASE_SSL=false
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

# ── Anthropic API key ────────────────────────────────────────────────
# Provider (anthropic / local) and model are picked per-request in the GUI
# Agent page and persisted in localStorage — no env vars needed for those.
# The only LLM setting that's env-only is the Anthropic API key, because
# there's no per-request override for it. Leave blank to use a local LLM
# (Ollama / LM Studio / llama.cpp / vLLM) configured entirely from the GUI.
ANTHROPIC_API_KEY=

# Ollama-only: cap the reported context window for the GUI's usage meter.
# Ollama advertises the model's architectural max (e.g. 131072) from
# /api/show, but at runtime it loads with a much smaller num_ctx unless you
# override it. Default cap is 65536; raise this if you've configured Ollama
# with a larger num_ctx. Has no effect on llama.cpp/vLLM/LM Studio.
# OLLAMA_CONTEXT_CAP=65536

# Override the default system prompt entirely (rare — VENDOR_NAME/USER_ROLE
# usually suffice).
# AGENT_SYSTEM_PROMPT=

# ── Todoist (optional) ───────────────────────────────────────────────
# Where tasks land by default. Section is optional — leave blank to drop
# tasks at the project root.
TODOIST_DEFAULT_PROJECT=Inbox
TODOIST_DEFAULT_SECTION=

# Todoist API token lives in todoist/.env (gitignored), not here:
#   echo "TODOIST_API_TOKEN=xxx" > todoist/.env

# ── Events scheduler ─────────────────────────────────────────────────
# Set DISABLE_SCHEDULER=1 to turn off the recurring events scrape.
# Standard 5-field cron. Default: daily at 06:00 local time.
# EVENTS_SCRAPE_CRON=0 6 * * *
# DISABLE_SCHEDULER=

# ── Other ────────────────────────────────────────────────────────────
# API_BASE_URL=http://localhost:3200
# DEFAULT_USER_EMAIL=default@local
# DEFAULT_USER_NAME=Default User

# --- Observability (Alloy → Loki) ---
# Full Loki push endpoint. Required when bringing up the observability profile.
# LOKI_PUSH_URL=http://loki.example.local:3100/loki/api/v1/push
# Host label attached to every shipped log line (used to filter in Grafana).
# LOG_HOST_LABEL=appvm
# LOG_ENV_LABEL=prod    # set to 'dev' on local dev machines
