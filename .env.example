# CRAM — example environment file. Copy to .env or run scripts/setup.sh
# to generate one interactively.

# ── Identity ─────────────────────────────────────────────────────────
# Shape the agent's system prompt and CRM workflow guidance.
VENDOR_NAME="Acme Corp"
USER_ROLE="Sales Engineer"

# Comma-separated internal email domains. Attendees/contacts from these
# domains are flagged "internal" (skipped for account creation + outreach).
# scripts/setup.sh seeds this from your work email. Acts as a bootstrap
# default until you curate the list in Settings → Internal Domains, after
# which it's ignored. INTERNAL_DOMAINS is accepted as an alias.
SELF_DOMAINS=""

# ── Postgres ─────────────────────────────────────────────────────────
POSTGRES_USER=crm
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=crm
POSTGRES_PORT=5432

# Connection string (defaults to the in-compose db service if unset)
# DATABASE_URL=postgres://crm:devpassword@db:5432/crm

# Set true when connecting to managed Postgres (Azure / RDS / etc.)
DATABASE_SSL=false
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

# ── Network access ───────────────────────────────────────────────────
# Host interface the app's published ports (3200 GUI/API, 3100 MCP) bind to.
# 127.0.0.1 = reachable from this machine only (default). Set to 0.0.0.0 to
# expose CRAM on your LAN (http://<this-machine-ip>:3200). There's no auth
# layer yet — only expose on a trusted network. Postgres always stays bound
# to 127.0.0.1 regardless of this setting.
BIND_ADDRESS=127.0.0.1

# ── Agent LLM (local by default) ─────────────────────────────────────
# The agent runs on a LOCAL LLM. By default that's Ollama running on the
# device itself (the machine hosting the app) — no API keys, nothing leaves
# your network. `local` is the only provider: an OpenAI-compatible inference
# server (Ollama / LM Studio / llama.cpp / vLLM).
# AGENT_PROVIDER=local
# Where the inference server lives. Default = Ollama on the Docker host (this
# device). Point at a LAN address (e.g. http://192.168.1.50:11434) to use an
# LLM on another machine.
# LOCAL_BASE_URL=http://host.docker.internal:11434
# Optional bearer token, only if your local endpoint requires auth.
# LOCAL_API_KEY=
#
# NOTE: there is no AGENT_MODEL knob. The model is a per-user choice in the GUI
# (Settings → Agent LLM); when unset, the app auto-selects one from whatever
# your server has installed (GET {LOCAL_BASE_URL}/v1/models).

# Ollama-only: cap the reported context window for the GUI's usage meter.
# Ollama advertises the model's architectural max (e.g. 131072) from
# /api/show, but at runtime it loads with a much smaller num_ctx unless you
# override it. Default cap is 262144 (256k); raise this if you've configured Ollama
# with a larger num_ctx. Has no effect on llama.cpp/vLLM/LM Studio.
# OLLAMA_CONTEXT_CAP=262144

# NOTE: there is no AGENT_SYSTEM_PROMPT knob. The agent's base system prompt is
# a per-user setting in the GUI (Settings → Agent System Prompt), stored in the
# database. When unset it falls back to a built-in default derived from
# VENDOR_NAME / USER_ROLE.

# ── Todoist (optional) ───────────────────────────────────────────────
# Where tasks land by default. Section is optional — leave blank to drop
# tasks at the project root.
TODOIST_DEFAULT_PROJECT=Inbox
TODOIST_DEFAULT_SECTION=

# Todoist API token lives in todoist/.env (gitignored), not here:
#   echo "TODOIST_API_TOKEN=xxx" > todoist/.env

# ── Other ────────────────────────────────────────────────────────────
# API_BASE_URL=http://localhost:3200
# DEFAULT_USER_EMAIL=default@local
# DEFAULT_USER_NAME=Default User

# --- Observability (Alloy → Loki) ---
# Full Loki push endpoint. Required when bringing up the observability profile.
# LOKI_PUSH_URL=http://loki.example.local:3100/loki/api/v1/push
# Host label attached to every shipped log line (used to filter in Grafana).
# LOG_HOST_LABEL=appvm
# LOG_ENV_LABEL=prod    # set to 'dev' on local dev machines

# ── Provisioning service (broker migration) ──────────────────────────
# AES-256-GCM master key for encrypting provisioning secrets at rest (the
# provisioning_secrets table). 32 bytes as a 64-char hex string or base64.
# Generate with: openssl rand -base64 32
# PROVISIONING_SECRETS_KEY=

# Roots for the provisioning service's runtime data/work + terraform stacks.
# Default to the service dir; override to relocate onto a container volume.
# PROVISIONING_ROOT=/app/api/src/services/provisioning
# PROVISIONING_TERRAFORM_ROOT=/app/api/src/services/provisioning/terraform
