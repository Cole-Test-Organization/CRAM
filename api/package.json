{
  "name": "cram-api",
  "version": "2.0.0",
  "description": "CRAM API — accounts, contacts, meetings, events, and the in-process agent loop",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "mcp": "tsx src/mcp/server.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node-pg-migrate --migrations-dir migrations up",
    "db:migrate:down": "node-pg-migrate --migrations-dir migrations down",
    "db:migrate:create": "node-pg-migrate --migrations-dir migrations create",
    "db:schema": "node ../dev/scripts/dump-schema.js",
    "db:clear": "node ../dev/scripts/clear-db.js",
    "test": "node --import tsx --test --test-concurrency=1 'test/*.test.js'"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "adm-zip": "^0.5.17",
    "express": "^5.2.1",
    "fastify": "^5.0.0",
    "node-pg-migrate": "^7.9.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "undici": "^6.25.0",
    "zod": "^3.25.1",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.2"
  }
}
