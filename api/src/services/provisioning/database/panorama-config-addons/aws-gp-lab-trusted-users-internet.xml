<panorama-config-add-on name="aws-gp-lab-trusted-users-internet">
  <!--
    GP lab "internet egress" config add-on for deployment aws-gp-lab-trusted-users.

    Verified against the live Panorama (read-only export, 2026-06-11): this add-on
    reproduces the live device-group + template + template-stack network/policy
    content exactly. See docs/gp-lab-live-vs-addon-diff.md for the full diff.

    FRESH-INSTANCE-SAFE: contains no host-specific values. Container names are
    ${...} placeholders resolved at apply time by PanoramaResourceAdapter from
    deployment onboarding config:
      ${templateStack} -> onboarding.templateStack (gp-lab-trusted-users-stack)
      ${template}      -> onboarding.template      (gp-lab-trusted-users-template)
      ${deviceGroup}   -> onboarding.deviceGroup   (gp-lab-trusted-users-dg)
      ${vsys}          -> onboarding.vsys          (vsys1)

    Literal values below describe topology, not a specific instance: zone names,
    interface names (ethernet1/1 untrust, ethernet1/2 trust), DNS/NTP servers,
    and the egress NAT interface. Dataplane IPs are intentionally absent — the
    template uses dhcp-client, so each firewall learns its untrust/trust address
    at boot. No static /32 host address appears here.

    EXCLUDED by design (artifact rules): mgmt/deviceconfig SYSTEM config beyond
    DNS/NTP, serial numbers, admin accounts / password hashes, license/auth-code
    remnants, vm-auth-keys, per-device DG/stack membership (onboarding owns
    containers + membership), certificate private keys, the PAN-OS 11.x
    auto-populated default_LR logical router, and rule UUIDs. The live lab has NO
    GlobalProtect portal/gateway config and NO certificates, so none are imported.
  -->
  <set xpath="/config/devices/entry[@name='localhost.localdomain']/template/entry[@name='${template}']">
    <config>
      <devices>
        <entry name="localhost.localdomain">
          <network>
            <interface>
              <ethernet>
                <entry name="ethernet1/1">
                  <layer3>
                    <ndp-proxy>
                      <enabled>no</enabled>
                    </ndp-proxy>
                    <sdwan-link-settings>
                      <upstream-nat>
                        <enable>no</enable>
                        <static-ip/>
                      </upstream-nat>
                      <enable>no</enable>
                      <ipv6-enable>no</ipv6-enable>
                    </sdwan-link-settings>
                    <lldp>
                      <enable>no</enable>
                    </lldp>
                    <dhcp-client>
                      <create-default-route>yes</create-default-route>
                      <default-route-metric>10</default-route-metric>
                    </dhcp-client>
                  </layer3>
                </entry>
                <entry name="ethernet1/2">
                  <layer3>
                    <ndp-proxy>
                      <enabled>no</enabled>
                    </ndp-proxy>
                    <sdwan-link-settings>
                      <upstream-nat>
                        <enable>no</enable>
                        <static-ip/>
                      </upstream-nat>
                      <enable>no</enable>
                      <ipv6-enable>no</ipv6-enable>
                    </sdwan-link-settings>
                    <lldp>
                      <enable>no</enable>
                    </lldp>
                    <dhcp-client>
                      <create-default-route>no</create-default-route>
                      <default-route-metric>100</default-route-metric>
                    </dhcp-client>
                  </layer3>
                </entry>
              </ethernet>
            </interface>
            <virtual-router>
              <entry name="default-vr">
                <ecmp>
                  <algorithm>
                    <ip-modulo/>
                  </algorithm>
                </ecmp>
                <protocol>
                  <bgp>
                    <routing-options>
                      <graceful-restart>
                        <enable>yes</enable>
                      </graceful-restart>
                    </routing-options>
                    <enable>no</enable>
                  </bgp>
                  <rip>
                    <enable>no</enable>
                  </rip>
                  <ospf>
                    <enable>no</enable>
                  </ospf>
                  <ospfv3>
                    <enable>no</enable>
                  </ospfv3>
                </protocol>
                <interface>
                  <member>ethernet1/1</member>
                  <member>ethernet1/2</member>
                </interface>
              </entry>
            </virtual-router>
          </network>
          <vsys>
            <entry name="${vsys}">
              <zone>
                <entry name="untrust">
                  <network>
                    <layer3>
                      <member>ethernet1/1</member>
                    </layer3>
                  </network>
                </entry>
                <entry name="trust">
                  <network>
                    <layer3>
                      <member>ethernet1/2</member>
                    </layer3>
                  </network>
                </entry>
              </zone>
              <import>
                <network>
                  <interface>
                    <member>ethernet1/1</member>
                    <member>ethernet1/2</member>
                  </interface>
                </network>
              </import>
            </entry>
          </vsys>
          <deviceconfig>
            <system>
              <dns-setting>
                <servers>
                  <primary>1.1.1.1</primary>
                  <secondary>8.8.8.8</secondary>
                </servers>
              </dns-setting>
              <ntp-servers>
                <primary-ntp-server>
                  <ntp-server-address>1.pool.ntp.org</ntp-server-address>
                  <authentication-type>
                    <none/>
                  </authentication-type>
                </primary-ntp-server>
                <secondary-ntp-server>
                  <ntp-server-address>2.pool.ntp.org</ntp-server-address>
                  <authentication-type>
                    <none/>
                  </authentication-type>
                </secondary-ntp-server>
              </ntp-servers>
            </system>
          </deviceconfig>
        </entry>
      </devices>
    </config>
  </set>

  <set xpath="/config/devices/entry[@name='localhost.localdomain']/template-stack/entry[@name='${templateStack}']">
    <settings>
      <default-vsys>${vsys}</default-vsys>
    </settings>
  </set>

  <set xpath="/config/devices/entry[@name='localhost.localdomain']/device-group/entry[@name='${deviceGroup}']">
    <pre-rulebase>
      <security>
        <rules>
          <entry name="to-internet">
            <target>
              <negate>no</negate>
            </target>
            <to>
              <member>untrust</member>
            </to>
            <from>
              <member>trust</member>
            </from>
            <source>
              <member>any</member>
            </source>
            <destination>
              <member>any</member>
            </destination>
            <source-user>
              <member>any</member>
            </source-user>
            <category>
              <member>any</member>
            </category>
            <saas-user-list>
              <member>any</member>
            </saas-user-list>
            <saas-tenant-list>
              <member>any</member>
            </saas-tenant-list>
            <application>
              <member>any</member>
            </application>
            <service>
              <member>application-default</member>
            </service>
            <source-hip>
              <member>any</member>
            </source-hip>
            <destination-hip>
              <member>any</member>
            </destination-hip>
            <action>allow</action>
            <log-start>no</log-start>
            <log-end>yes</log-end>
          </entry>
        </rules>
      </security>
      <nat>
        <rules>
          <entry name="to-internet">
            <source-translation>
              <dynamic-ip-and-port>
                <interface-address>
                  <interface>ethernet1/1</interface>
                </interface-address>
              </dynamic-ip-and-port>
            </source-translation>
            <target>
              <negate>no</negate>
            </target>
            <to>
              <member>untrust</member>
            </to>
            <from>
              <member>trust</member>
            </from>
            <source>
              <member>any</member>
            </source>
            <destination>
              <member>any</member>
            </destination>
            <service>any</service>
          </entry>
        </rules>
      </nat>
    </pre-rulebase>
  </set>
</panorama-config-add-on>
